{
  "version": "1.0",
  "tools": [
    {
      "name": "workspace.read",
      "description": "Read file contents from workspace",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "File path relative to workspace root"}
        },
        "required": ["path"]
      },
      "wiki_file": "tools/read_file.md"
    },
    {
      "name": "workspace.write",
      "description": "Write file contents to workspace",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "File path relative to workspace root"},
          "content": {"type": "string", "description": "Content to write"}
        },
        "required": ["path", "content"]
      },
      "wiki_file": "tools/write_file.md"
    },
    {
      "name": "workspace.list",
      "description": "List directory contents in workspace",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "Directory path relative to workspace root", "default": "."}
        }
      },
      "wiki_file": "tools/list_files.md"
    },
    {
      "name": "workspace.delete",
      "description": "Delete file or directory from workspace",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "Path to delete"},
          "recursive": {"type": "boolean", "description": "Delete directories recursively", "default": false}
        },
        "required": ["path"]
      },
      "wiki_file": "tools/delete_file.md"
    },
    {
      "name": "workspace.compile",
      "description": "Compile source code (Go, Python, C, C++, Rust)",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "Source file path"},
          "language": {"type": "string", "enum": ["go", "python", "c", "cpp", "rust", "auto"], "default": "auto"}
        },
        "required": ["path"]
      },
      "wiki_file": "tools/compile.md"
    },
    {
      "name": "workspace.run",
      "description": "Execute binary or script in workspace",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {"type": "string", "description": "Executable/script path"},
          "args": {"type": "array", "items": {"type": "string"}, "default": []},
          "timeout": {"type": "integer", "default": 30}
        },
        "required": ["path"]
      },
      "wiki_file": "tools/run.md"
    },
    {
      "name": "workspace.search",
      "description": "Search code with grep",
      "parameters": {
        "type": "object",
        "properties": {
          "pattern": {"type": "string", "description": "Regex pattern"},
          "path": {"type": "string", "default": "."},
          "file_pattern": {"type": "string"},
          "context_lines": {"type": "integer", "default": 2}
        },
        "required": ["pattern"]
      },
      "wiki_file": "tools/search.md"
    },
    {
      "name": "wiki.lookup",
      "description": "Look up tool/guide documentation",
      "parameters": {
        "type": "object",
        "properties": {
          "topic": {"type": "string", "description": "Tool name (workspace.read) or guide name (getting_started)"}
        },
        "required": ["topic"]
      },
      "wiki_file": "tools/wiki_lookup.md"
    }
  ],
  "guides": [
    {"name": "getting_started", "file": "guides/getting_started.md"},
    {"name": "go_development", "file": "guides/go_development.md"},
    {"name": "python_development", "file": "guides/python_development.md"},
    {"name": "searching_code", "file": "guides/searching_code.md"}
  ]
}